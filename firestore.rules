rules_version = '2';
service cloud.firestore { match /databases/{database}/documents {
  function signedIn(){ return request.auth != null; }
  function owner(field){ return signedIn() && resource.data[field] == request.auth.uid; }
  match /users/{uid} {
    allow read: if signedIn() && request.auth.uid == uid;
    allow create: if signedIn() && request.auth.uid == uid && !request.resource.data.keys().hasAny(['systemRole','operationalRole','staffStatus','staffAssignedBy','staffAssignedAt','settlement','kycStatus','verificationStatus']);
    allow update: if signedIn() && request.auth.uid == uid
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email','displayName','photoURL','updatedAt']);
  }
  match /companies/{id} { allow read: if owner('ownerId'); allow write: if false; }
  match /rfqs/{id} { allow read: if owner('buyerId'); allow write: if false; }
  match /lots/{id} { allow read: if owner('ownerId'); allow write: if false; }
  match /bids/{id} { allow read: if owner('supplierId'); allow write: if false; }
  match /pickups/{id} { allow read: if owner('exporterId'); allow write: if false; }
  match /shipments/{id} { allow read: if owner('exporterId'); allow write: if false; }
  match /compliance_actions/{id} { allow read: if owner('ownerId'); allow write: if false; }
  match /payments/{id} { allow read: if owner('payerId'); allow write: if false; }
  match /documents/{id} { allow read: if owner('ownerId'); allow write: if false; }
  match /activityLogs/{id} { allow read: if owner('actorId'); allow write: if false; }
  match /integrationEvents/{id} { allow read,write: if false; }
  match /contracts/{id} { allow read,write: if false; }
  match /messages/{id} { allow read,write: if false; }
  match /payouts/{id} { allow read,write: if false; }
}}
